#!/bin/sh
#
# Git pre-commit hook: verify code formatting with Spotless.
#

echo "Running Spotless format check..."

./mvnw spotless:check -q

if [ $? -ne 0 ]; then
  echo ""
  echo "ERROR: Code formatting issues found."
  echo "  Run './mvnw spotless:apply' to fix them, then stage and commit again."
  echo ""
  exit 1
fi
